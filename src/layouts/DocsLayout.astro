---
import "../styles/global.css";
import "@fontsource-variable/lexend";
import { Picture } from "astro:assets";
import Enni from "@assets/Enni.png";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

interface Props {
	title: string;
	slug?: string;
}

const { title, slug } = Astro.props;

const allDocs = await getCollection("docs");

const sectionOrder = ["Protocol", "Token", "Reference"];

interface NavItem {
	title: string;
	id: string;
	order: number;
	children: NavItem[];
}

const grouped: Record<string, NavItem[]> = {};

for (const doc of allDocs) {
	const section = doc.data.section || "Protocol";
	if (!grouped[section]) grouped[section] = [];

	const parts = doc.id.split("/");

	if (parts.length === 1) {
		let existing = grouped[section].find((d) => d.id === doc.id);
		if (!existing) {
			grouped[section].push({
				title: doc.data.title,
				id: doc.id,
				order: doc.data.order ?? 99,
				children: [],
			});
		} else {
			existing.title = doc.data.title;
			existing.order = doc.data.order ?? existing.order;
		}
	} else {
		const parentId = parts[0];
		let parent = grouped[section].find((d) => d.id === parentId);
		if (!parent) {
			parent = { title: parentId, id: parentId, order: 99, children: [] };
			grouped[section].push(parent);
		}
		parent.children.push({
			title: doc.data.title,
			id: doc.id,
			order: doc.data.order ?? 99,
			children: [],
		});
	}
}

for (const key of Object.keys(grouped)) {
	grouped[key].sort((a, b) => a.order - b.order);
	for (const item of grouped[key]) {
		item.children.sort((a, b) => a.order - b.order);
	}
}

const flatDocs: { title: string; id: string }[] = [];
for (const section of sectionOrder) {
	if (grouped[section]) {
		for (const item of grouped[section]) {
			flatDocs.push({ title: item.title, id: item.id });
			for (const child of item.children) {
				flatDocs.push({ title: child.title, id: child.id });
			}
		}
	}
}

const currentIndex = flatDocs.findIndex((d) => d.id === slug);
const prevDoc = currentIndex > 0 ? flatDocs[currentIndex - 1] : null;
const nextDoc = currentIndex < flatDocs.length - 1 ? flatDocs[currentIndex + 1] : null;

function isActive(docId: string): boolean {
	return docId === slug;
}

function isParentActive(parentId: string): boolean {
	return slug === parentId || (slug?.startsWith(parentId + "/") ?? false);
}

const searchIndex = allDocs.map((doc) => {
	const raw = doc.body || "";
	const cleaned = raw
		.replace(/---[\s\S]*?---/g, "")
		.replace(/<[^>]+>/g, "")
		.replace(/[#*`\[\]()!|>]/g, "")
		.replace(/\n+/g, " ")
		.replace(/\s+/g, " ")
		.trim();
	return {
		title: doc.data.title,
		id: doc.id,
		section: doc.data.section || "Protocol",
		content: cleaned,
	};
});
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — ENNI Docs</title>
  <meta name="description" content="Documentation for the ENNI Protocol. Decentralized, immutable, and non-custodial CDP on Ethereum. Borrow stablecoins at 0% interest." />
  <!-- open graph -->
  <meta property="og:title" content={`${title} — ENNI Docs`} />
  <meta property="og:description" content="Documentation for the ENNI Protocol. Decentralized, immutable, and non-custodial CDP on Ethereum. Borrow stablecoins at 0% interest." />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="enni.ch" />
  <meta property="og:image" content="/EnniOg.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <!-- twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} — ENNI Docs`} />
  <meta name="twitter:description" content="Documentation for the ENNI Protocol. Decentralized, immutable, and non-custodial CDP on Ethereum. Borrow stablecoins at 0% interest." />
  <meta name="twitter:image" content="/EnniOg.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="manifest" href="/site.webmanifest">
</head>
<body
	class="bg-white text-neutral-900 antialiased"
	style="font-family: 'Lexend Variable', sans-serif;"
>
	<script type="application/json" id="search-index-data" set:html={JSON.stringify(searchIndex)} />

	<!-- Navbar -->
	<nav class="fixed top-0 inset-x-0 z-50 bg-white/80 backdrop-blur-xl border-b border-neutral-200/60 h-14">
		<div class="h-full px-6 flex items-center justify-between">
			<div class="flex items-center gap-3">
				<a href="/" class="no-underline flex items-center gap-2.5">
					<Picture
						src={Enni}
						formats={['avif', 'webp']}
						alt="ENNI logo"
						quality={28}
						height={28}
						densities={[1.5, 2]}
						class="block w-7 h-7 rounded-md"
					/>
					<span class="text-sm font-normal tracking-tight">ENNI</span>
				</a>
				<span class="text-neutral-300 text-sm">/</span>
				<span class="text-sm text-neutral-700">Docs</span>
			</div>
			<div class="flex items-center gap-3">
				<a href="/" class="text-xs md:text-sm font-normal text-neutral-900 bg-white border border-neutral-200 hover:bg-neutral-50 px-4 py-2 rounded-lg transition-colors no-underline">
					<span class="sm:hidden">Home</span>
					<span class="hidden sm:inline">Return Home</span>
				</a>
				<a href="https://testnet.enni.ch" class="text-xs md:text-sm font-normal text-white bg-neutral-900 hover:bg-neutral-700 px-4 py-2 rounded-lg transition-colors no-underline">Enter App</a>
				<button
					id="docs-menu-toggle"
					class="md:hidden cursor-pointer w-9 h-9 flex items-center justify-center rounded-lg border border-neutral-200 hover:bg-neutral-50 transition-colors"
					aria-label="Toggle docs menu"
				>
					<svg id="docs-icon-open" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
						<path d="M4 6h16M4 12h16M4 18h16"/>
					</svg>
					<svg id="docs-icon-close" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden">
						<path d="M18 6L6 18M6 6l12 12"/>
					</svg>
				</button>
			</div>
		</div>
	</nav>

	<div class="pt-14 flex min-h-screen">
		<!-- Sidebar -->
		<aside id="docs-sidebar" class="hidden md:block fixed top-14 left-0 bottom-0 w-64 border-r border-neutral-200/60 overflow-y-auto">
			<div class="px-5 py-6">
				<!-- Search -->
				<div class="relative mb-6">
					<div class="flex items-center gap-2 border border-neutral-200 rounded-lg px-3 py-2 cursor-text" id="search-trigger">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a3a3a3" stroke-width="2">
							<circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
						</svg>
						<span class="text-sm text-neutral-400">Search docs...</span>
					</div>
				</div>

				<!-- Nav sections -->
				<nav class="space-y-7">
					{sectionOrder.map((section) =>
						grouped[section] && (
							<div>
								<p class="text-[11px] font-medium tracking-widest text-neutral-800 uppercase mb-3 px-3">{section}</p>
								<ul class="space-y-0.5 list-none p-0 m-0">
									{grouped[section].map((item) => (
										<li>
											{item.children.length > 0 ? (
												<div>
													<div class="flex items-center">
														<a
															href={`/docs/${item.id}`}
															class:list={[
																"flex-1 block text-[13px] py-2 px-3 rounded-l-md no-underline transition-colors",
																isActive(item.id)
																	? "text-neutral-900 font-normal bg-[#e9f0e4]"
																	: "text-neutral-700 font-normal hover:text-neutral-900 hover:bg-neutral-50",
															]}
														>
															{item.title}
														</a>
														<button
															class:list={[
																"docs-chevron cursor-pointer w-8 h-8 flex items-center justify-center rounded-r-md transition-colors shrink-0",
																isParentActive(item.id)
																	? "bg-[#e9f0e4]"
																	: "hover:bg-neutral-50",
															]}
															data-parent={item.id}
															aria-label={`Toggle ${item.title} submenu`}
														>
															<svg
																width="12"
																height="12"
																viewBox="0 0 24 24"
																fill="none"
																stroke="currentColor"
																stroke-width="2"
																stroke-linecap="round"
																class:list={[
																	"transition-transform",
																	isParentActive(item.id) ? "rotate-90" : "",
																]}
															>
																<path d="M9 18l6-6-6-6"/>
															</svg>
														</button>
													</div>
													<ul
														class:list={[
															"list-none p-0 m-0 pl-3 space-y-0.5 mt-0.5 overflow-hidden transition-all",
															isParentActive(item.id) ? "" : "hidden",
														]}
														data-children={item.id}
													>
														{item.children.map((child) => (
															<li>
																<a
																	href={`/docs/${child.id}`}
																	class:list={[
																		"block text-[13px] py-1.5 px-3 rounded-md no-underline transition-colors border-l border-neutral-200 ml-1",
																		isActive(child.id)
																			? "text-neutral-900 font-normal bg-[#e9f0e4] border-neutral-900"
																			: "text-neutral-500 font-normal hover:text-neutral-900 hover:bg-neutral-50",
																	]}
																>
																	{child.title}
																</a>
															</li>
														))}
													</ul>
												</div>
											) : (
												<a
													href={`/docs/${item.id}`}
													class:list={[
														"block text-[13px] py-2 px-3 rounded-md no-underline transition-colors",
														isActive(item.id)
															? "text-neutral-900 font-normal bg-[#e9f0e4]"
															: "text-neutral-700 font-normal hover:text-neutral-900 hover:bg-neutral-50",
													]}
												>
													{item.title}
												</a>
											)}
										</li>
									))}
								</ul>
							</div>
						)
					)}
				</nav>
			</div>
		</aside>

		<!-- Content -->
		<main class="md:ml-64 flex-1 min-w-0">
			<div class="px-8 md:px-14 py-10 md:py-12">
				<article class="max-w-170 mx-auto prose-enni">
					<slot />
				</article>

				<!-- Prev / Next -->
				{(prevDoc || nextDoc) && (
					<div class="max-w-170 mx-auto mt-12 pt-6 border-t border-neutral-200 flex items-center justify-between">
						{prevDoc ? (
							<a href={`/docs/${prevDoc.id}`} class="flex items-center gap-2 text-sm font-light text-neutral-700 hover:text-neutral-900 no-underline transition-colors">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
								{prevDoc.title}
							</a>
						) : <div />}
						{nextDoc ? (
							<a href={`/docs/${nextDoc.id}`} class="flex items-center gap-2 text-sm font-light text-neutral-700 hover:text-neutral-900 no-underline transition-colors">
								{nextDoc.title}
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
							</a>
						) : <div />}
					</div>
				)}
			</div>
		</main>
	</div>

	<!-- Search modal -->
	<div id="search-modal" class="hidden fixed inset-0 z-100">
		<div class="absolute inset-0 bg-black/40" id="search-backdrop"></div>
		<div class="relative max-w-lg mx-auto mt-24 bg-white rounded-xl border border-neutral-200 overflow-hidden shadow-lg">
			<div class="flex items-center gap-3 px-4 py-3 border-b border-neutral-200">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a3a3a3" stroke-width="2">
					<circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
				</svg>
				<input
					id="search-input"
					type="text"
					placeholder="Search docs..."
					class="flex-1 text-sm font-light outline-none bg-transparent text-neutral-900 placeholder:text-neutral-400"
					autocomplete="off"
				/>
				<kbd class="text-[11px] text-neutral-800 border border-neutral-200 rounded px-1.5 py-0.5">esc</kbd>
			</div>
			<div id="search-results" class="max-h-96 overflow-y-auto p-2">
				<p class="text-sm font-light text-neutral-400 px-3 py-4 text-center">Type to search...</p>
			</div>
		</div>
	</div>

	<script>
		import Fuse from "fuse.js";

		const searchIndexEl = document.getElementById("search-index-data");
		const searchIndex = searchIndexEl ? JSON.parse(searchIndexEl.textContent || "[]") : [];

		const fuse = new Fuse(searchIndex, {
			keys: [
				{ name: "title", weight: 2 },
				{ name: "content", weight: 1 },
			],
			threshold: 0.35,
			ignoreLocation: true,
			includeMatches: true,
			minMatchCharLength: 2,
		});

		function getSnippet(content: string, query: string, length = 120): string {
			const lower = content.toLowerCase();
			const idx = lower.indexOf(query.toLowerCase());
			if (idx === -1) return content.slice(0, length) + "...";
			const start = Math.max(0, idx - 40);
			const end = Math.min(content.length, idx + length - 40);
			let snippet = content.slice(start, end);
			if (start > 0) snippet = "..." + snippet;
			if (end < content.length) snippet = snippet + "...";
			return snippet;
		}

		// Chevron toggles
		document.querySelectorAll(".docs-chevron").forEach((btn) => {
			btn.addEventListener("click", () => {
				const parent = btn.getAttribute("data-parent");
				if (!parent) return;
				const children = document.querySelector(`[data-children="${parent}"]`);
				const svg = btn.querySelector("svg");
				if (children && svg) {
					children.classList.toggle("hidden");
					svg.classList.toggle("rotate-90");
				}
			});
		});

		// Mobile menu
		const toggle = document.getElementById("docs-menu-toggle");
		const sidebar = document.getElementById("docs-sidebar");
		const iconOpen = document.getElementById("docs-icon-open");
		const iconClose = document.getElementById("docs-icon-close");

		if (toggle && sidebar && iconOpen && iconClose) {
			toggle.addEventListener("click", () => {
				const isHidden = sidebar.classList.contains("hidden");
				if (isHidden) {
					sidebar.classList.remove("hidden");
					sidebar.classList.add("fixed", "inset-0", "top-14", "z-40", "bg-white", "w-full", "border-r-0");
					sidebar.classList.remove("w-64", "border-r");
					iconOpen.classList.add("hidden");
					iconClose.classList.remove("hidden");
				} else {
					sidebar.classList.add("hidden");
					sidebar.classList.remove("fixed", "inset-0", "top-14", "z-40", "bg-white", "w-full", "border-r-0");
					sidebar.classList.add("w-64", "border-r");
					iconOpen.classList.remove("hidden");
					iconClose.classList.add("hidden");
				}
			});

			sidebar.querySelectorAll("a").forEach((link) => {
				link.addEventListener("click", () => {
					if (window.innerWidth < 768) {
						sidebar.classList.add("hidden");
						sidebar.classList.remove("fixed", "inset-0", "top-14", "z-40", "bg-white", "w-full", "border-r-0");
						sidebar.classList.add("w-64", "border-r");
						iconOpen.classList.remove("hidden");
						iconClose.classList.add("hidden");
					}
				});
			});
		}

		// Search
		const searchTrigger = document.getElementById("search-trigger");
		const searchModal = document.getElementById("search-modal");
		const searchBackdrop = document.getElementById("search-backdrop");
		const searchInput = document.getElementById("search-input") as HTMLInputElement | null;
		const searchResults = document.getElementById("search-results");

		function openSearch() {
			if (!searchModal || !searchInput || !searchResults) return;
			searchModal.classList.remove("hidden");
			searchInput.value = "";
			searchInput.focus();
			searchResults.innerHTML = '<p style="font-size:14px;font-weight:300;color:#a3a3a3;padding:16px 12px;text-align:center;">Type to search...</p>';
		}

		function closeSearch() {
			if (!searchModal) return;
			searchModal.classList.add("hidden");
		}

		if (searchTrigger) searchTrigger.addEventListener("click", openSearch);
		if (searchBackdrop) searchBackdrop.addEventListener("click", closeSearch);

		document.addEventListener("keydown", (e) => {
			if (e.key === "k" && (e.metaKey || e.ctrlKey)) {
				e.preventDefault();
				openSearch();
			}
			if (e.key === "Escape") closeSearch();
		});

		if (searchInput && searchResults) {
			searchInput.addEventListener("input", () => {
				const q = searchInput.value.trim();
				if (!q || q.length < 2) {
					searchResults.innerHTML = '<p style="font-size:14px;font-weight:300;color:#a3a3a3;padding:16px 12px;text-align:center;">Type to search...</p>';
					return;
				}
				const results = fuse.search(q, { limit: 8 });
				if (results.length === 0) {
					searchResults.innerHTML = '<p style="font-size:14px;font-weight:300;color:#a3a3a3;padding:16px 12px;text-align:center;">No results</p>';
					return;
				}
				searchResults.innerHTML = results.map((r: any) => {
					const snippet = getSnippet(r.item.content, q);
					return '<a href="/docs/' + r.item.id + '" style="display:block;padding:12px;text-decoration:none;border-radius:8px;margin-bottom:2px;" onmouseover="this.style.background=\'#f5f5f5\'" onmouseout="this.style.background=\'transparent\'">'
						+ '<div style="font-size:14px;font-weight:400;color:#171717;margin-bottom:4px;">' + r.item.title + '</div>'
						+ '<div style="font-size:12px;font-weight:300;color:#737373;line-height:1.5;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">' + snippet + '</div>'
						+ '<div style="font-size:11px;font-weight:400;color:#a3a3a3;margin-top:4px;">' + r.item.section + '</div>'
						+ '</a>';
				}).join("");
			});
		}
	</script>
</body>
</html>