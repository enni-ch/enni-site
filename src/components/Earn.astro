---
---
<section id="savings" class="max-w-4xl mx-auto px-8 py-32">
	<h2 class="text-3xl sm:text-4xl font-light tracking-tight text-center mb-4">
		Savings for your stablecoins
	</h2>
	<p class="text-base font-light text-neutral-800 text-center mb-16 max-w-lg mx-auto">
		Deposit enUSD or enCHF. Conservative rate backed by overcollateralized ETH lending.
	</p>

	<div class="border border-neutral-900 rounded-xl overflow-hidden max-w-xl mx-auto">
		<div class="h-28 bg-purple-50 relative">
			<svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg">
				<pattern id="grid-savings" width="20" height="20" patternUnits="userSpaceOnUse">
					<path d="M0 0l20 20M20 0l-20 20" stroke="rgba(147,51,234,0.1)" stroke-width="1" />
				</pattern>
				<rect width="100%" height="100%" fill="url(#grid-savings)" />
			</svg>
			<div class="absolute left-7 top-1/2 -translate-y-1/2 w-16 h-16 rounded-full bg-white border border-neutral-900 flex items-center justify-center">
				<img src="/farming.svg" alt="Savings" class="w-9 h-9" />
			</div>
		</div>
		<div class="border-t border-neutral-900">
			<div class="grid grid-cols-2 text-sm font-light">
				<div class="px-7 py-4 text-neutral-800 border-b border-neutral-200 border-r border-r-neutral-200">APR</div>
				<div class="px-7 py-4 text-neutral-900 border-b border-neutral-200">5%, forever</div>
				<div class="px-7 py-4 text-neutral-800 border-b border-neutral-200 border-r border-r-neutral-200">Lockup</div>
				<div class="px-7 py-4 text-neutral-900 border-b border-neutral-200">None</div>
				<div class="px-7 py-4 text-neutral-800 border-b border-neutral-200 border-r border-r-neutral-200">Deposit cap</div>
				<div class="px-7 py-4 text-neutral-900 border-b border-neutral-200">None</div>
				<div class="px-7 py-4 text-neutral-800 border-r border-r-neutral-200">Yield source</div>
				<div class="px-7 py-4 text-neutral-900">Overcollateralized lending & protocol revenue</div>
			</div>
		</div>
	</div>

	<div class="text-center mt-14 flex items-center justify-center gap-6">
		<a
			href="https://testnet.enni.ch/earn"
			class="text-base font-light text-neutral-800 hover:text-neutral-900 underline underline-offset-4 decoration-neutral-300 hover:decoration-neutral-900 transition-colors inline-flex items-center gap-1.5"
		>
			Start saving
			<svg width="12" height="12" viewBox="0 0 12 12" fill="none">
				<path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</a>
		<a
			href="/docs/savings/sustainability"
			class="text-base font-light text-neutral-800 hover:text-neutral-900 underline underline-offset-4 decoration-neutral-300 hover:decoration-neutral-900 transition-colors inline-flex items-center gap-1.5"
		>
			How is 5% sustainable?
			<svg width="12" height="12" viewBox="0 0 12 12" fill="none">
				<path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</a>
	</div>
</section>