---
---
<section id="home" class="min-h-screen flex items-center justify-center px-6">
	<div class="max-w-2xl text-center">
		<h1 class="anim d1 text-4xl sm:text-5xl md:text-6xl font-light leading-tight tracking-tight mb-6">
			Get 0% interest loans against your ETH
			<img
				src="/eth.svg"
				alt="ETH"
				class="inline-block h-9 sm:h-11 md:h-13 align-baseline -mb-1"
			/>
			<br />
		</h1>
		<p class="anim d2 text-base sm:text-lg font-light text-neutral-800 max-w-lg mx-auto mb-10">
			Borrow stablecoins with zero interest. <span class="text-neutral-900 bg-neutral-100 px-2 py-0.5 rounded">Earn 5% on deposits.</span> Immutable. Free forever.
		</p>
		<div class="anim d3 flex items-center justify-center gap-4">
			<a
				href="https://testnet.enni.ch"
				class="text-sm font-normal text-white bg-neutral-900 hover:bg-neutral-700 px-7 py-3 rounded-lg transition-colors no-underline inline-flex items-center gap-2"
			>
				Get Started
			</a>
			<a
				href="/docs"
				class="text-sm font-normal text-neutral-900 bg-white border border-neutral-200 hover:bg-neutral-50 px-7 py-3 rounded-lg transition-colors no-underline inline-flex items-center gap-2"
				aria-label="Learn more about ENNI protocol documentation"
			>
				Read the docs
				<svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="pointer-events-none">
					<path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</a>
		</div>
	</div>
</section>