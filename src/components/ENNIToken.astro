---
import { Picture } from "astro:assets";
import Enni from "@assets/Enni.png";
import enUSD from "@assets/enUSD.png";
---

<section id="enni-token" class="max-w-4xl mx-auto px-8 py-32">
  <h2 class="text-3xl sm:text-4xl font-light tracking-tight text-center mb-4">$ENNI</h2>
  <p class="text-base font-light text-neutral-800 text-center mb-16 max-w-lg mx-auto">
    The ecosystem token. Fixed supply. All protocol revenue flows to stakers.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-3xl mx-auto">
    <!-- Left — token card -->
<div class="border border-neutral-900 rounded-xl p-8 flex flex-col justify-between border-t-4 border-t-emerald-500">      <div>
        <Picture
          src={Enni}
          formats={['avif', 'webp']}
          alt="ENNI logo."
          quality={48}
          height={56}
          densities={[1.5, 2]}
          class="block shrink-0 rounded-full border border-neutral-200 w-14 h-14 mb-6"
        />
        <h3 class="text-2xl font-light tracking-tight mb-3">21,000,000</h3>
        <p class="text-sm font-light text-neutral-800 leading-relaxed mb-4">
          Fixed supply, enforced by immutable code. No mint function beyond the cap. No inflation, ever.
        </p>
      </div>
      <div class="space-y-2 pt-4 border-t border-neutral-200">
        <div class="flex justify-between text-sm">
          <span class="font-light text-neutral-800">Initial allocation</span>
          <span class="font-light">1,000,000</span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="font-light text-neutral-800">Farming emission</span>
          <span class="font-light">20,000,000</span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="font-light text-neutral-800">Emission period</span>
          <span class="font-light">30 years</span>
        </div>
      </div>
      <p class="text-xs font-light text-neutral-800 mt-4">
        Initial allocation is for contributors and early community. Distributed with a locked vesting schedule, not instantly.
      </p>
    </div>

    <!-- Right — staking rewards -->
<div class="border border-neutral-900 rounded-xl p-8 flex flex-col justify-between border-t-4 border-t-blue-500">      <div>
        <p class="text-sm uppercase tracking-widest text-neutral-800 mb-6">Stake ENNI, earn</p>
        <div class="space-y-5">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-blue-50 border border-blue-200 flex items-center justify-center shrink-0">
              <img src="/eth.svg" alt="ETH" class="w-5 h-5" />
            </div>
            <div>
              <p class="text-base font-light tracking-tight">WETH</p>
              <p class="text-xs font-light text-neutral-800">3% of seized collateral from CDP liquidations, donated to the vault</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-emerald-50 border border-emerald-200 flex items-center justify-center shrink-0">
              <Picture
                src={enUSD}
                formats={['avif', 'webp']}
                alt="enUSD"
                quality={28}
                height={24}
                densities={[1.5, 2]}
                class="block shrink-0 w-6 h-6 rounded-full"
              />
            </div>
            <div>
              <p class="text-base font-light tracking-tight">enUSD</p>
              <p class="text-xs font-light text-neutral-800">0.5% fee from DirectMint redemptions, donated to the vault</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-amber-50 border border-amber-200 flex items-center justify-center shrink-0">
              <Picture
                src={Enni}
                formats={['avif', 'webp']}
                alt="ENNI"
                quality={28}
                height={24}
                densities={[1.5, 2]}
                class="block shrink-0 w-6 h-6 rounded-full"
              />
            </div>
            <div>
              <p class="text-base font-light tracking-tight">ENNI</p>
              <p class="text-xs font-light text-neutral-800">Native staking rewards from MasterChef farming emissions</p>
            </div>
          </div>
        </div>
      </div>
      <p class="text-xs font-light text-neutral-800 pt-6 border-t border-neutral-200 mt-6">
        No lockups. No cooldowns. No withdrawal fees. Claim anytime.
      </p>
    </div>
  </div>

  <!-- Yield source -->
  <div class="max-w-3xl mx-auto mt-8 border border-neutral-200 rounded-xl px-7 py-6">
    <h3 class="text-base tracking-tight mb-2">Where does the yield come from?</h3>
    <p class="text-sm font-light text-neutral-800 leading-relaxed">
      Real protocol revenue, not printed tokens. WETH comes from 3% of liquidation collateral. enUSD comes from 0.5% redemption fees. Both are sent directly from the contracts to the vault. ENNI rewards come from the 30 year emission schedule. As the ecosystem grows, more revenue sources can flow to stakers.
    </p>
  </div>

<div class="text-center mt-8 flex items-center justify-center gap-6">
  <a
    href="https://index.enni.ch/docs"
    target="_blank"
    rel="noopener noreferrer"
    class="text-sm font-light text-neutral-800 hover:text-neutral-900 underline underline-offset-4 decoration-neutral-300 hover:decoration-neutral-900 transition-colors inline-flex items-center gap-1.5"
  >
    View tokenomics
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
      <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
  <a
    href="https://testnet.enni.ch/earn"
    target="_blank"
    rel="noopener noreferrer"
    class="text-sm font-light text-neutral-800 hover:text-neutral-900 underline underline-offset-4 decoration-neutral-300 hover:decoration-neutral-900 transition-colors inline-flex items-center gap-1.5"
  >
    Stake now
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
      <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</div>
</section>