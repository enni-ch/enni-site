---
import "../styles/global.css";
import "@fontsource-variable/lexend";

import Navbar from "@components/Navbar.astro"
import Hero from "@components/Hero.astro";
import HowItWorks from "@components/HowItWorks.astro";
import Stablecoins from "@components/Stablecoins.astro";
import Products from "@components/Products.astro";
import Comparison from "@components/Comparison.astro"
import Calculator from "@components/Calculator.astro"
import ENNIToken from "@components/ENNIToken.astro";
import Audits from "@components/Audits.astro"
import FAQ from "@components/FAQ.astro"
import Closing from "@components/Closing.astro"

const {
  title = "ENNI — 0% Interest Loans Against Your ETH",
  description = "Borrow stablecoins against your ETH with zero interest. Noncustodial, immutable, and free forever. No governance, no admin keys.",
} = Astro.props

const siteUrl = "https://index.enni.ch"
const ogImageUrl = `${siteUrl}/EnniBanner.webp`
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- open graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="enni.ch" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

<body
  class="bg-white text-neutral-900 antialiased"
  style="font-family: 'Lexend Variable', sans-serif;"
>
  <Navbar/>
  <main>
    <Hero />
    <HowItWorks />
    <Stablecoins />
    <Products/>
    <Comparison/>
    <Calculator/>
    <ENNIToken/>
    <Audits/>
    <FAQ/>
    <Closing/>
  </main>
</body>
</html>